# Copiar a .env para desarrollo local (no versionar .env con secretos reales).
# Nombres verificados contra src/plugins/db.js, src/plugins/bigquery.js, src/server.js,
# src/routes/auth.js y src/routes/ai.js. Valores de despliegue reales en infra/04_backend.sh.

# Postgres — en local, vía Cloud SQL Auth Proxy corriendo en 127.0.0.1:5432
# (en Cloud Run, PGHOST es el socket /cloudsql/<INSTANCE>, ver infra/04_backend.sh)
PGHOST=127.0.0.1
DCSMART_DB=postgres
ANALYTICS_DB=dcsmart_analytics
PGUSER_RO=analytics_ro
PGPASSWORD_RO=
PGUSER_APP=analytics_app
PGPASSWORD_APP=

# BigQuery (requiere ADC del desarrollador: gcloud auth application-default login)
BQ_PROJECT=dc-smart-mvp
BQ_DATASET=dcsmart_analytics

# Auth de la plataforma (JWT propio, distinto del de producción)
ANALYTICS_ALLOWED_ROLES=super_admin;dcsmart
ANALYTICS_JWT_SECRET=
FRONTEND_ORIGIN=http://localhost:5173

# Login con Google (Identity Services). Mismo Client ID que la app de gestión
# (proyecto GCP dc-smart-mvp) — requiere agregar el origen de esta app en
# "Authorized JavaScript origins" del Client ID en Google Cloud Console.
GOOGLE_CLIENT_ID=

# Secreto compartido con dcsmart/backend/.env — SSO y API interna de permisos.
INTERNAL_SHARED_SECRET=

# Vertex AI (Gemini Flash vía IAM — requiere rol aiplatform.user en la identidad ADC)
VERTEX_LOCATION=us-central1
AI_MODEL=gemini-2.5-flash

PORT=8080
